{
  "name": "004-Nuxt",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0 <23 || >=24.11.0 <25 || >=26"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=4096 nuxt build",
    "dev": "nuxt dev",
    "preview": "npm run build && wrangler --cwd .output dev",
    "postinstall": "patch-package && nuxt prepare",
    "lint": "eslint .",
    "security:regression": "node scripts/security-regression.mjs",
    "typecheck": "nuxt typecheck",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed:test-user": "node scripts/seed-test-user.mjs",
    "deploy": "npm run build && wrangler --cwd .output deploy --keep-vars",
    "cf-typegen": "npm run build && wrangler --cwd .output types"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.87",
    "@internationalized/date": "^3.12.2",
    "@libsql/client": "^0.17.4",
    "@nuxt/ui": "^4.9.0",
    "@tanstack/table-core": "^8.21.3",
    "@unovis/ts": "^1.6.6",
    "@unovis/vue": "^1.6.6",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "barcode-detector": "^3.2.0",
    "date-fns": "^4.4.0",
    "drizzle-orm": "1.0.0-rc.3",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "scule": "^1.3.0",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.39",
    "vue-chrts": "^2.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@adonisjs/hash": "^10.1.0",
    "@nuxt/eslint": "^1.16.0",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^17.4.2",
    "drizzle-kit": "1.0.0-rc.3",
    "eslint": "^10.6.0",
    "nitro-cloudflare-dev": "^0.2.2",
    "patch-package": "^8.0.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.105.0"
  },
  "packageManager": "npm@10.9.0"
}
