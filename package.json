    "@tanstack/table-core": "^8.21.3",
    "@unovis/ts": "^1.6.4",
    "@unovis/vue": "^1.6.4",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "barcode-detector": "^3.1.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.2",
    "nuxt-charts": "^2.1.4",
